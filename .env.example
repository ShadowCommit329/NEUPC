# ============================================================================
# NEUPC Website — Environment Variables
# ============================================================================
# Local dev:   Copy this file to `.env.local` and fill in the values.
#              cp .env.example .env.local
#
# Vercel:      Add these in Project Settings → Environment Variables.
#              https://vercel.com/docs/projects/environment-variables
#
# IMPORTANT: Never commit `.env.local` to version control.
# ============================================================================

# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-public-key
SUPABASE_SERVICE_KEY=your-service-role-secret-key

# ── NextAuth.js ──────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
# Vercel auto-sets AUTH_URL from VERCEL_URL, but set AUTH_SECRET manually.
AUTH_SECRET=your-nextauth-secret

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Get these from: https://console.cloud.google.com/apis/credentials
# For Vercel, add your production domain to Authorized redirect URIs:
#   https://your-domain.vercel.app/api/auth/callback/google
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# ── Site URL ─────────────────────────────────────────────────────────────────
# Used for SEO metadata, sitemaps, canonical URLs, and OG images.
# On Vercel, set this to your production domain (e.g. https://neupc.vercel.app).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Email / Nodemailer (optional) ────────────────────────────────────────────
# Required for contact form emails and notifications.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@yourdomain.com

# ── Google Cloud Storage ──────────────────────────────────────────────────────
# Used for storing event cover images via Google Drive API.
# 1. Enable the Drive API: https://console.cloud.google.com/apis/api/drive.googleapis.com
# 2. IAM → Service Accounts → create account → generate JSON key
# 3. Copy client_email + private_key from the JSON key file
# 4. Create a Drive folder, share it with the service account email (Editor role)
# 5. Copy the folder ID from the Drive URL (the long string after /folders/)
# NOTE: GDRIVE_PRIVATE_KEY must use literal \n (not real newlines) when stored in .env
GDRIVE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GDRIVE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
GDRIVE_FOLDER_ID=your-drive-folder-id
